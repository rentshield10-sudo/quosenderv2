{
  "name": "quosenderv2",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,sender,web -c cyan,magenta,green \"npm run dev:server\" \"npm run dev:sender\" \"npm run dev:web\"",
    "dev:server": "npm run dev -w packages/server",
    "dev:sender": "npm run dev -w packages/sender",
    "dev:web": "npm run dev -w packages/web",
    "db:migrate": "npm run db:migrate -w packages/server",
    "db:seed": "npm run db:seed -w packages/server",
    "db:reset": "npm run db:reset -w packages/server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
